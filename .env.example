# ── Site ────────────────────────────────────────────────────────────────
# Public URL of the deployed site (used for SEO metadata and sitemap)
NEXT_PUBLIC_SITE_URL=https://bukdigital.co.za

# Google Analytics / Tag Manager measurement ID (leave empty to disable)
NEXT_PUBLIC_GA_ID=

# ── Google Calendar (bookings) — configure ONE of the two options ───────
# Option A: Service account (recommended)
#   1. Create a service account in Google Cloud Console and enable the
#      Google Calendar API.
#   2. Share your Google Calendar with the service account's email address
#      and give it "Make changes to events" permission.
#   3. Paste the values from the service account's JSON key below.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
# Your calendar's ID (Calendar settings → "Integrate calendar"), e.g.
# yourname@gmail.com
GOOGLE_CALENDAR_ID=

# Option B: OAuth2 (books on your own calendar as you)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# ── Email (booking confirmations + contact form) ────────────────────────
# For Gmail: use an App Password (Google Account → Security → App passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Where owner notifications are sent (defaults to SMTP_USER)
CONTACT_EMAIL=ndebouod@gmail.com
